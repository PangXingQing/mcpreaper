{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mcpreaper: install deps (.venv)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "${workspaceFolder}/requirements.txt"
      ],
      "problemMatcher": []
    },
    {
      "label": "mcpreaper: run server",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "${workspaceFolder}/main.py"
      ],
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "mcpreaper: check reaper connection",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": [
        "${workspaceFolder}/scripts/check_reaper_connection.py"
      ],
      "problemMatcher": []
    },
    {
      "label": "mcpreaper: check web 2307",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/check_web_2307.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "mcpreaper: activate reapy server instructions",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Write-Output 'In Reaper, load and run script: scripts/enable_reapy_server.lua, then start the MCP server.'"
      ],
      "problemMatcher": []
    }
  ]
}
